    "plt.xticks(rotation=15)\n",
    "plt.legend(loc=\"lower right\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"outputs/model_comparison.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "df_results.round(4)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step10-header",
   "metadata": {},
   "source": [
    "## Step 10 — SHAP Feature Importance\n",
    "\n",
    "Using SHAP's `LinearExplainer` on the best Logistic Regression model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "shap-importance",
   "metadata": {},
   "outputs": [],
   "source": [
    "lr_model = trained_models[\"Logistic Regression\"]\n",
    "explainer = shap.LinearExplainer(lr_model, X_test_scaled)\n",
    "shap_values = explainer.shap_values(X_test_scaled)\n",
    "\n",
    "X_display = X_test_scaled.copy()\n",
    "X_display.columns = [FEATURE_LABELS[f] for f in FEATURES]\n",
    "\n",
    "plt.figure()\n",
    "shap.summary_plot(shap_values, X_display, plot_type=\"bar\", show=False)\n",
    "plt.title(\"Feature Importance (SHAP — Logistic Regression)\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"outputs/shap_importance.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step11-header",
   "metadata": {},
   "source": [
    "## Step 11 — SHAP Beeswarm Plot\n",
    "\n",
    "Shows direction of feature effects (positive = increases termination risk)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "shap-beeswarm",
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure()\n",
    "shap.summary_plot(shap_values, X_display, show=False)\n",
