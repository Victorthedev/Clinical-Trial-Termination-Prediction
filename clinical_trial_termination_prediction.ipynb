   "cell_type": "markdown",
   "id": "step14-header",
   "metadata": {},
   "source": [
    "## Step 14 — Batch Prediction from CSV\n",
    "\n",
    "Upload a CSV with columns: `phase`, `enrollment`, `sponsor_class`, `completion_date`, `study_type`  \n",
    "and score all trials at once."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "batch-prediction",
   "metadata": {},
   "outputs": [],
   "source": [
    "def preprocess_batch(df_batch):\n",
    "    df_b = df_batch.copy()\n",
    "\n",
    "    phase_map = {\"PHASE1\": 1, \"PHASE2\": 2, \"PHASE3\": 3, \"PHASE4\": 4, \"NA\": 0, \"EARLY_PHASE1\": 0}\n",
    "    df_b[\"phase_clean\"] = df_b.get(\"phase\", pd.Series([\"NA\"] * len(df_b))).map(phase_map).fillna(0)\n",
    "\n",
    "    df_b[\"enrollment\"] = pd.to_numeric(df_b.get(\"enrollment\", 0), errors=\"coerce\").fillna(0)\n",
    "    df_b[\"log_enrollment\"] = np.log1p(df_b[\"enrollment\"].clip(upper=df_b[\"enrollment\"].quantile(0.99)))\n",
    "\n",
    "    df_b[\"is_industry\"] = (df_b.get(\"sponsor_class\", \"\") == \"INDUSTRY\").astype(int)\n",
    "\n",
    "    df_b[\"completion_date\"] = pd.to_datetime(df_b.get(\"completion_date\", pd.NaT), errors=\"coerce\")\n",
    "    df_b[\"duration_missing\"] = df_b[\"completion_date\"].isnull().astype(int)\n",
    "\n",
    "    df_b[\"is_interventional\"] = (df_b.get(\"study_type\", \"\") == \"INTERVENTIONAL\").astype(int)\n",
    "\n",
    "    return df_b[FEATURES]\n",
    "\n",
    "\n",
    "# Example: create a small sample batch inline\n",
    "sample_batch = pd.DataFrame([\n",
    "    {\"phase\": \"PHASE1\",  \"enrollment\": 30,   \"sponsor_class\": \"NIH\",      \"completion_date\": \"2024-01-01\", \"study_type\": \"INTERVENTIONAL\"},\n",
    "    {\"phase\": \"PHASE2\",  \"enrollment\": 200,  \"sponsor_class\": \"INDUSTRY\", \"completion_date\": None,          \"study_type\": \"INTERVENTIONAL\"},\n",
    "    {\"phase\": \"PHASE3\",  \"enrollment\": 1500, \"sponsor_class\": \"INDUSTRY\", \"completion_date\": \"2025-06-30\", \"study_type\": \"INTERVENTIONAL\"},\n",
    "    {\"phase\": \"NA\",      \"enrollment\": 50,   \"sponsor_class\": \"OTHER\",    \"completion_date\": None,          \"study_type\": \"OBSERVATIONAL\"},\n",
    "    {\"phase\": \"PHASE4\",  \"enrollment\": 800,  \"sponsor_class\": \"INDUSTRY\", \"completion_date\": \"2026-12-31\", \"study_type\": \"INTERVENTIONAL\"},\n",
    "])\n",
    "\n",
    "X_batch = preprocess_batch(sample_batch)\n",
    "X_batch_scaled = pd.DataFrame(scaler.transform(X_batch), columns=FEATURES)\n",
    "batch_scores = lr_model.predict_proba(X_batch_scaled)[:, 1]\n",
    "\n",
    "sample_batch[\"risk_score\"] = batch_scores\n",
    "sample_batch[\"risk_category\"] = sample_batch[\"risk_score\"].apply(\n",
    "    lambda s: \"HIGH\" if s >= 0.6 else (\"MEDIUM\" if s >= 0.4 else \"LOW\")\n",
    ")\n",
    "\n",
    "display(sample_batch[[\"phase\", \"enrollment\", \"sponsor_class\", \"study_type\", \"risk_score\", \"risk_category\"]]\n",
    "        .style.format({\"risk_score\": \"{:.1%}\"}))"
   ]
  },
