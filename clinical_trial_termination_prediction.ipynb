    "plt.tight_layout()\n",
    "plt.savefig(\"outputs/shap_beeswarm.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step12-header",
   "metadata": {},
   "source": [
    "## Step 12 — Demo: Predict a Single Trial\n",
    "\n",
    "Change the inputs below and re-run to predict termination risk for any trial."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "single-prediction",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Edit these values ---\n",
    "trial_input = {\n",
    "    \"phase\":           \"PHASE2\",       # PHASE1 / PHASE2 / PHASE3 / PHASE4 / NA\n",
    "    \"enrollment\":      150,             # expected number of participants\n",
    "    \"sponsor_class\":   \"INDUSTRY\",     # INDUSTRY or NIH/OTHER\n",
    "    \"has_completion\":  True,            # True if a completion date is known\n",
    "    \"study_type\":      \"INTERVENTIONAL\" # INTERVENTIONAL or OBSERVATIONAL\n",
    "}\n",
    "# -------------------------\n",
    "\n",
    "phase_map = {\"PHASE1\": 1, \"PHASE2\": 2, \"PHASE3\": 3, \"PHASE4\": 4, \"NA\": 0, \"EARLY_PHASE1\": 0}\n",
    "\n",
    "features_dict = {\n",
    "    \"phase_clean\":       phase_map.get(trial_input[\"phase\"], 0),\n",
    "    \"log_enrollment\":    np.log1p(trial_input[\"enrollment\"]),\n",
    "    \"is_industry\":       int(trial_input[\"sponsor_class\"] == \"INDUSTRY\"),\n",
    "    \"duration_missing\":  int(not trial_input[\"has_completion\"]),\n",
    "    \"is_interventional\": int(trial_input[\"study_type\"] == \"INTERVENTIONAL\")\n",
    "}\n",
    "\n",
    "X_input = pd.DataFrame([features_dict])[FEATURES]\n",
    "X_input_scaled = pd.DataFrame(scaler.transform(X_input), columns=FEATURES)\n",
    "\n",
    "risk_score = lr_model.predict_proba(X_input_scaled)[0][1]\n",
    "\n",
    "if risk_score >= 0.6:\n",
    "    category = \"HIGH\"\n",
    "elif risk_score >= 0.4:\n",
    "    category = \"MEDIUM\"\n",
    "else:\n",
    "    category = \"LOW\"\n",
    "\n",
    "print(f\"Termination Risk Score: {risk_score:.1%}\")\n",
    "print(f\"Risk Category:          {category}\")\n",
    "print()\n",
    "print(\"Feature values used:\")\n",
    "for k, v in features_dict.items():\n",
    "    print(f\"  {FEATURE_LABELS[k]:<28} {v:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step13-header",
   "metadata": {},
   "source": [
    "## Step 13 — SHAP Waterfall for Single Trial"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
